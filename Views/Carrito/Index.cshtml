@model IEnumerable<(int Id, string Nombre, double Precio)>
@{
    ViewData["Title"] = "Carrito de Compras";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-success">
                    <i class="bi bi-cart3 me-2"></i>Carrito de Compras
                </h1>
                <p class="text-muted small">JULIO OLIVER GARCIA QUINTANA — 22340342</p>
            </div>

            <div class="d-grid mb-4">
                <a asp-action="Create" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Agregar producto
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-list-ul me-2"></i>Lista de productos</span>
                    <span class="badge bg-white text-success">@Model.Count() items</span>
                </div>

                <div class="card-body p-0">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-cart-x display-4 d-block mb-2"></i>
                            <p class="mb-0">Tu carrito está vacío</p>
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <span>
                                        <i class="bi bi-tag-fill text-success me-2"></i>
                                        <strong>@item.Nombre</strong>
                                    </span>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="text-success fw-semibold">
                                            $@item.Precio.ToString("N2")
                                        </span>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash3"></i>
                                        </a>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Total:</span>
                        <span class="fs-5 fw-bold text-success">
                            $@Model.Sum(p => p.Precio).ToString("N2")
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>