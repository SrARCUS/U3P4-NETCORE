@{
    ViewData["Title"] = "Carrito de Compras";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="text-center mb-4">
                <h1 class="fw-bold text-success">
                    <i class="bi bi-cart3 me-2"></i>Carrito de Compras
                </h1>
                <p class="text-muted small">JULIO OLIVER GARCIA QUINTANA — 22340342</p>
            </div>

            @* Campo: Nombre del comprador *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-person-fill me-2"></i><strong>Datos del comprador</strong>
                </div>
                <div class="card-body">
                    <label for="input-comprador" class="form-label">Nombre del comprador</label>
                    <input type="text" id="input-comprador" class="form-control"
                           placeholder="Escribe tu nombre..." />
                    <div id="nombre-comprador-display" class="mt-2 text-muted small"></div>
                </div>
            </div>

            @* Formulario: Agregar producto *@
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-plus-circle me-2"></i><strong>Agregar producto</strong>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label for="input-nombre" class="form-label">Nombre del producto</label>
                        <input type="text" id="input-nombre" class="form-control"
                               placeholder="Ej. Manzanas" />
                    </div>
                    <div class="mb-3">
                        <label for="input-precio" class="form-label">Precio ($)</label>
                        <input type="number" id="input-precio" class="form-control"
                               placeholder="Ej. 25.50" step="0.01" min="0.01" />
                    </div>
                    <div class="d-grid">
                        <button onclick="agregarProducto()" class="btn btn-success btn-lg">
                            <i class="bi bi-plus-circle me-2"></i>Agregar al carrito
                        </button>
                    </div>
                </div>
            </div>

            @* Lista de productos *@
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-list-ul me-2"></i>Lista de productos</span>
                    <span id="count-carrito" class="badge bg-white text-success">0 items</span>
                </div>

                <div class="card-body p-0">
                    <ul id="lista-carrito" class="list-group list-group-flush">
                        @* Renderizado por site.js *@
                    </ul>
                </div>

                <div class="card-footer bg-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted">Total:</span>
                        <span id="total-carrito" class="fs-5 fw-bold text-success">$0.00</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/site.js"></script>
}
